		<properties node_id="24" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\xb4\x00\x00\x01\x08\x00\x00\x05~\x00\x00\x03e\x00\x00\x01\xb4\x00\x00\x01$\x00\x00\x05~\x00\x00\x03e\x00\x00\x00\x00\x00\x00\x00\x00\n\x00\x00\x00\x01\xb4\x00\x00\x01$\x00\x00\x05~\x00\x00\x03e', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data import Table, Domain, StringVariable\n\n# Column names (change if needed)\nTEXT_COLUMN = "text"\nTITLE_VALUE = "lee_before_presidency"  # &lt;- your title\n\n# Get text data\ntry:\n    texts = in_data.documents\nexcept:\n    col_idx = in_data.domain.index(TEXT_COLUMN)\n    texts = [str(row[col_idx]) for row in in_data]\n\n# Merge all tweets into ONE document\nmerged_text = " ".join(texts)\n\n# Create variables\ntext_var = StringVariable("text")\ntitle_var = StringVariable("title")\n\n# Create domain (no attributes, only metas)\ndomain = Domain([], metas=[text_var, title_var])\n\n# Create table with one row\nout_data = Table.from_list(domain, [[merged_text, TITLE_VALUE]])', 'filename': None}], 'scriptText': 'from Orange.data import Table, Domain, StringVariable\n\n# Column names (change if needed)\nTEXT_COLUMN = "processed_text"\nTITLE_VALUE = "moon_before_presidency"  # &lt;- your title\n\n# Get text data\ntry:\n    texts = in_data.documents\nexcept:\n    col_idx = in_data.domain.index(TEXT_COLUMN)\n    texts = [str(row[col_idx]) for row in in_data]\n\n# Merge all tweets into ONE document\nmerged_text = " ".join(texts)\n\n# Create variables\ntext_var = StringVariable("text")\ntitle_var = StringVariable("title")\n\n# Create domain (no attributes, only metas)\ndomain = Domain([], metas=[text_var, title_var])\n\n# Create table with one row\nout_data = Table.from_list(domain, [[merged_text, TITLE_VALUE]])', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa8\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="25" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\xcf\x00\x00\x00\xf8\x00\x00\x04\x99\x00\x00\x03U\x00\x00\x00\xcf\x00\x00\x01\x14\x00\x00\x04\x99\x00\x00\x03U\x00\x00\x00\x00\x00\x00\x00\x00\n\x00\x00\x00\x00\xcf\x00\x00\x01\x14\x00\x00\x04\x99\x00\x00\x03U', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data import Table, Domain, StringVariable\n\n# Column names (change if needed)\nTEXT_COLUMN = "text"\nTITLE_VALUE = "lee_before_presidency"  # &lt;- your title\n\n# Get text data\ntry:\n    texts = in_data.documents\nexcept:\n    col_idx = in_data.domain.index(TEXT_COLUMN)\n    texts = [str(row[col_idx]) for row in in_data]\n\n# Merge all tweets into ONE document\nmerged_text = " ".join(texts)\n\n# Create variables\ntext_var = StringVariable("text")\ntitle_var = StringVariable("title")\n\n# Create domain (no attributes, only metas)\ndomain = Domain([], metas=[text_var, title_var])\n\n# Create table with one row\nout_data = Table.from_list(domain, [[merged_text, TITLE_VALUE]])', 'filename': None}], 'scriptText': 'from Orange.data import Table, Domain, StringVariable\n\n# Column names (change if needed)\nTEXT_COLUMN = "processed_text"\nTITLE_VALUE = "moon_during_presidency"  # &lt;- your title\n\n# Get text data\ntry:\n    texts = in_data.documents\nexcept:\n    col_idx = in_data.domain.index(TEXT_COLUMN)\n    texts = [str(row[col_idx]) for row in in_data]\n\n# Merge all tweets into ONE document\nmerged_text = " ".join(texts)\n\n# Create variables\ntext_var = StringVariable("text")\ntitle_var = StringVariable("title")\n\n# Create domain (no attributes, only metas)\ndomain = Domain([], metas=[text_var, title_var])\n\n# Create table with one row\nout_data = Table.from_list(domain, [[merged_text, TITLE_VALUE]])', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa8\x00\x00\x00h\x01\xff\xff\xff\xff\x0