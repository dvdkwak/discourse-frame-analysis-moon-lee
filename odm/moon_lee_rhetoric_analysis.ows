		<properties node_id="37" format="literal">{'autocommit': True, 'controlAreaVisible': True, 'method_index': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x12\x00\x00\x00!\x00\x00\x037\x00\x00\x01\xce\x00\x00\x00\x12\x00\x00\x00=\x00\x00\x037\x00\x00\x01\xce\x00\x00\x00\x00\x00\x00\x00\x00\n\x00\x00\x00\x00\x12\x00\x00\x00=\x00\x00\x037\x00\x00\x01\xce', 'selection': 7, 'hdp': {'K': 15, 'T': 150, 'alpha': 1, 'eta': 0.01, 'gamma': 1, 'kappa': 1, 'tau': 64}, 'lda': {'num_topics': 8}, 'lsi': {'num_topics': 10}, 'nmf': {'num_topics': 10}, '__version__': 2, 'context_settings': []}</properties>
		<properties node_id="38" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\xf9\x00\x00\x01\xc3\x00\x00\x04\xa8\x00\x00\x04 \x00\x00\x00\xf9\x00\x00\x01\xdf\x00\x00\x04\xa8\x00\x00\x04 \x00\x00\x00\x00\x00\x00\x00\x00\n\x00\x00\x00\x00\xf9\x00\x00\x01\xdf\x00\x00\x04\xa8\x00\x00\x04 ', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data import Table, Domain, StringVariable\n\n# Column names (change if needed)\nTEXT_COLUMN = "text"\nTITLE_VALUE = "lee_before_presidency"  # &lt;- your title\n\n# Get text data\ntry:\n    texts = in_data.documents\nexcept:\n    col_idx = in_data.domain.index(TEXT_COLUMN)\n    texts = [str(row[col_idx]) for row in in_data]\n\n# Merge all tweets into ONE document\nmerged_text = " ".join(texts)\n\n# Create variables\ntext_var = StringVariable("text")\ntitle_var = StringVariable("title")\n\n# Create domain (no attributes, only metas)\ndomain = Domain([], metas=[text_var, title_var])\n\n# Create table with one row\nout_data = Table.from_list(domain, [[merged_text, TITLE_VALUE]])', 'filename': None}], 'scriptText': '#\n#  Script to find the dominant Topic column and write that to a sepperate attribute for every Document.\n#\n\nimport numpy as np\nfrom Orange.data import Domain, DiscreteVariable\n\n# ===== GET TOPIC COLUMNS =====\ntopic_vars = [var for var in in_data.domain.attributes if "Topic" in var.name]\ntopic_indices = [in_data.domain.attributes.index(var) for var in topic_vars]\n\ntopic_labels = [f"Topic {i+1}" for i in range(len(topic_vars))]\n\ndom_var = DiscreteVariable("Dominant Topic", values=topic_labels)\n\nX = in_data.X.toarray()\n\ndominant = []\n\nfor row in X:\n    topic_values = row[topic_indices]\n    idx = int(np.argmax(topic_values))\n    dominant.append(idx)  # KEEP AS INTEGER (IMPORTANT)\n\n# ===== CREATE NEW DOMAIN =====\nnew_domain = Domain(\n    in_data.domain.attributes,\n    in_data.domain.class_vars,\n    in_data.domain.metas + (dom_var,)\n)\n\nout_data = in_data.transform(new_domain)\n\n# IMPORTANT FIX: assign via metas index\nmeta_index = len(out_data.domain.metas) - 1\n\nwith out_data.unlocked():\n    for i, val in enumerate(dominant):\n        out_data.metas[i, meta_index] = val', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa8\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="39" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00a\x00\x00\x01\x16\x00\x00\tl\x00\x00\x03\xbd\x00\x00\x00a\x00\x00\x012\x00\x00\tl\x00\x00\x03\xbd\x00\x00\x00\x00\x00\x00\x00\x00\n\x00\x00\x00\x00a\x00\x00\x012\x00\x00\tl\x00\x00\x03\xbd', 'select_rows': False, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [], '__version__': 1}</properties>
		<properties node_id="40" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\xf9\x00\x00\x01\xc3\x00\x00\x04\xa8\x00\x00\x04 \x00\x00\x00\xf9\x00\x00\x01\xdf\x00\x00\x04\xa8\x00\x00\x04 \x00\x00\x00\x00\x00\x00\x00\x00\n\x00\x00\x00\x00\xf9\x00\x00\x01\xdf\x00\x00\x04\xa8\x00\x00\x04 ', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data import Table, Domain, StringVariable\n\n# Column names (change if needed)\nTEXT_COLUMN = "text"\nTITLE_VALUE = "lee_before_presidency"  # &lt;- your title\n\n# Get text data\ntry:\n    texts = in_data.documents\nexcept:\n    col_idx = in_data.domain.index(TEXT_COLUMN)\n    texts = [str(row[col_idx]) for row in in_data]\n\n# Merge all tweets into ONE document\nmerged_text = " ".join(texts)\n\n# Create variables\ntext_var = StringVariable("text")\ntitle_var = StringVariable("title")\n\n# Create domain (no attributes, only metas)\ndomain = Domain([], metas=[text_var, title_var])\n\n# Create table with one row\nout_data = Table.from_list(domain, [[merged_text, TITLE_VALUE]])', 'filename': None}], 'scriptText': '#\n#  Script to find the dominant Topic column and write that to a sepperate attribute for every Document.\n#\n\nimport numpy as np\nfrom Orange.data import Domain, DiscreteVariable\n\n# ===== GET TOPIC COLUMNS =====\ntopic_vars = [var for var in in_data.domain.attributes if "Topic" in var.name]\ntopic_indices = [in_data.domain.attributes.index(var) for var in topic_vars]\n\ntopic_labels = [f"Topic {i+1}" for i in range(len(topic_vars))]\n\ndom_var = DiscreteVariable("Dominant Topic", values=topic_labels)\n\nX = in_data.X.toarray()\n\ndominant = []\n\nfor row in X:\n    topic_values = row[topic_indices]\n    idx = int(np.argmax(topic_values))\n    dominant.append(idx)  # KEEP AS INTEGER (IMPORTANT)\n\n# ===== CREATE NEW DOMAIN =====\nnew_domain = Domain(\n    in_data.domain.attributes,\n    in_data.domain.class_vars,\n    in_data.domain.metas + (dom_var,)\n)\n\nout_data = in_data.transform(new_domain)\n\n# IMPORTANT FIX: assign via metas index\nmeta_index = len(out_data.domain.metas) - 1\n\nwith out_data.unlocked():\n    for i, val in enumerate(dominant):\n        out_data.metas[i, meta_index] = val', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa8\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
